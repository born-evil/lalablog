---
import { getCollection } from "astro:content";
import GalleryView from "../../components/GalleryView.astro";

const PAGE_SIZE = 12;

const allItems = (await getCollection("gallery")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const totalPages = Math.max(1, Math.ceil(allItems.length / PAGE_SIZE));

export async function getStaticPaths() {
  const pageSize = 12;
  const items = (await getCollection("gallery")).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );
  const total = Math.max(1, Math.ceil(items.length / pageSize));

  return Array.from({ length: Math.max(0, total - 1) }, (_, index) => {
    const page = index + 2;
    const start = (page - 1) * pageSize;
    const end = start + pageSize;

    return {
      params: { page: String(page) },
      props: {
        items: items.slice(start, end),
        currentPage: page,
        totalPages: total
      }
    };
  });
}

const { page } = Astro.params;
const pageNumber = Number(page);

if (!Number.isInteger(pageNumber) || pageNumber < 2 || pageNumber > totalPages) {
  return Astro.redirect("/gallery/");
}

const { items, currentPage } = Astro.props;
---

<GalleryView items={items} currentPage={currentPage} totalPages={totalPages} />
